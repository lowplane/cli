{
  "$schema": "./tokens.schema.json",
  "name": "optiqor",
  "tagline": "Detect. Fix. Prove.",
  "subtitle": "Helm chart cost optimization · security as a bonus",
  "homepage": "https://optiqor.dev",
  "license": "Apache-2.0",

  "color": {
    "ink": {
      "0": "#0A0A0B",
      "1": "#111114",
      "2": "#16161A",
      "3": "#1C1C22",
      "4": "#24242B",
      "5": "#33333D",
      "6": "#5C5C68",
      "7": "#9C9CA8",
      "8": "#C8C8D0",
      "9": "#EDEDEE"
    },
    "accent": {
      "cyan": "#22D3EE",
      "cyan-dim": "#0E7490",
      "cyan-glow": "rgba(34, 211, 238, 0.18)"
    },
    "signal": {
      "high": "#FF6B6B",
      "med":  "#F59E0B",
      "low":  "#22D3EE",
      "ok":   "#34D399"
    },
    "border": {
      "subtle": "#1F1F25",
      "default": "#2A2A33",
      "strong": "#3A3A45"
    }
  },

  "type": {
    "sans": "Geist, ui-sans-serif, system-ui, -apple-system, Segoe UI, Helvetica Neue, Arial",
    "mono": "\"Geist Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
    "scale": {
      "display": "clamp(48px, 9vw, 96px)",
      "h1": "clamp(36px, 5vw, 56px)",
      "h2": "clamp(24px, 3vw, 36px)",
      "h3": "20px",
      "body-lg": "18px",
      "body": "16px",
      "small": "14px",
      "micro": "12px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    },
    "tracking": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.04em",
      "caps": "0.12em"
    },
    "leading": {
      "tight": 1.1,
      "snug": 1.25,
      "normal": 1.5,
      "loose": 1.7
    }
  },

  "radius": {
    "sm": "3px",
    "md": "6px",
    "lg": "10px",
    "pill": "999px"
  },

  "space": {
    "px": "1px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "96px",
    "10": "128px"
  },

  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "200ms",
      "slow": "320ms"
    },
    "ease": {
      "out": "cubic-bezier(0.16, 1, 0.3, 1)",
      "in-out": "cubic-bezier(0.65, 0, 0.35, 1)"
    }
  },

  "disclosure": {
    "sandbox": "Sandbox accuracy: ±40%. Install the Optiqor agent for exact numbers (optiqor.dev/get).",
    "agent": "Agent accuracy: ±15%. Backed by 30 days of Prometheus + your AWS bill."
  }
}
